# Xclusivetech .gitignore

# OS Files
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.project
.pydevproject
.settings/
*.sublime-project
*.sublime-workspace

# IDE
.vscode/
.idea/
*.code-workspace
*.sublime-settings

# Dependencies (if using npm/yarn in future)
node_modules/
package-lock.json
yarn.lock
pnpm-lock.yaml

# Build files
dist/
build/
*.min.css
*.min.js

# Environment variables
.env
.env.local
.env.*.local

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Temporary files
tmp/
temp/
*.tmp
*.bak

# Cache
.cache/
.eslintcache
.stylelintcache

# Testing
coverage/
.nyc_output/

# Production
out/
deploy/

# Backup files
*.backup
*.backup.*
*.orig

# OS generated files
$RECYCLE.BIN/
ehthumbs.db

# Directories
node_modules/
.next/
.nuxt/
dist/

# Files to ignore
*.pem
*.key
config.local.json
secrets.json
